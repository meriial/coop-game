{
  "name": "workshop-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "login": "DRY_RUN=1 bash setup.sh",
    "login:dev": "DRY_RUN=1 bash setup.sh http://localhost:8787",
    "dev:server": "pnpm --filter server dev",
    "dev:starter": "pnpm --filter starter dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "deploy": "pnpm run deploy:wrangler",
    "deploy:wrangler": "pnpm --filter frontend build && pnpm --filter server run deploy",
    "test": "npm run test --prefix server && npm run test --prefix packages/mcp-server"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
